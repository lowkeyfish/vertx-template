{
  "timestamp": {
    "$resolver": "timestamp",
    "pattern": "yyyy-MM-dd'T'HH:mm:ss.SSSX"
  },
  "traceId": "${ctx:trace_id:-}",
  "spanId": "${ctx:span_id:-}",
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "data": {
    "$resolver": "message",
    "fallbackKey": "message"
  },
  "exception": {
    "$resolver": "exception",
    "field": "message"
  },
  "stacktrace": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stackTrace": {
      "stringified": true
    }
  }
}